# --- 飞书配置 ---
# 飞书开放平台 → 应用凭证
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# --- DeepSeek 配置 ---
# platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Kimi 配置 ---
# platform.moonshot.cn → API Keys
KIMI_API_KEY=sk-your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# --- 角色映射 ---
# 飞书 user_id，多个用英文逗号分隔
ADMIN_USERS=
CHILD_USERS=
TUTOR_USERS=

# --- 管理后台 ---
ADMIN_PASSWORD=change_me
REPORT_TIME=09:00

# --- 服务器 ---
HOST=0.0.0.0
PORT=8080
